APP_NAME=Jeuncy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:3000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de donnees MySQL (le dev tourne contre une vraie instance, ex. Clever
# Cloud DEV plan gratuit — voir CLAUDE.md section "Base de donnees de dev")
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jeuncy
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@jeuncy.fr"
MAIL_FROM_NAME="${APP_NAME}"

# URL du frontend (apps/web), utilisee pour les liens dans les emails et les
# redirections OAuth/Stripe
FRONTEND_URL=http://localhost:5173

# JWT (access token courte duree, JSON + refresh token longue duree, cookie
# httpOnly) — generer des secrets aleatoires uniques en local, ex:
# php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=
JWT_TTL_MINUTES=15
JWT_REFRESH_SECRET=
JWT_REFRESH_TTL_MINUTES=10080

# Google OAuth (connexion candidat/entreprise) — optionnel en local, laisser
# vide pour desactiver ce mode de connexion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Stripe (offres payantes) — cles de test depuis le dashboard Stripe
# (dashboard.stripe.com/test/apikeys), le webhook secret est fourni par
# `stripe listen` en local ou par la configuration du endpoint en production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Prix fixe de publication d'une offre, en centimes (49,00 €)
STRIPE_JOB_OFFER_PRICE_CENTS=4900

# Resend (emails transactionnels) — laisser vide pour logger les emails au
# lieu de les envoyer (voir App\Services\MailService)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@jeuncy.fr

VITE_APP_NAME="${APP_NAME}"
