generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  CANDIDATE
  COMPANY
  CFA
  ADMIN
}

enum JobOfferStatus {
  DRAFT
  PUBLISHED
  EXPIRED
  ARCHIVED
}

enum ContractType {
  ALTERNANCE
  SAISONNIER
  BENEVOLAT
}

enum ApplicationStatus {
  SENT
  SEEN
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum NotificationType {
  NEW_APPLICATION
  APPLICATION_STATUS_CHANGED
  PAYMENT_SUCCEEDED
  VIDEO_ROOM_INVITE
  JOB_OFFER_EXPIRING
}

enum VideoRoomStatus {
  SCHEDULED
  LIVE
  ENDED
}

// ---------------------------------------------------------------------------
// Auth / comptes
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  role         UserRole
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  candidateProfile CandidateProfile?
  company          Company?
  cfaOrganization  CfaOrganization?
  notifications    Notification[]
  payments         Payment[]

  hostedVideoRooms       VideoRoom[] @relation("VideoRoomHost")
  participatedVideoRooms VideoRoom[] @relation("VideoRoomParticipant")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Profil candidat
// ---------------------------------------------------------------------------

model CandidateProfile {
  id         String    @id @default(cuid())
  userId     String    @unique @map("user_id")
  firstName  String    @map("first_name")
  lastName   String    @map("last_name")
  phone      String?
  birthDate  DateTime? @map("birth_date")
  address    String?
  city       String?
  postalCode String?   @map("postal_code")
  bio        String?   @db.Text
  photoUrl   String?   @map("photo_url")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Cascade : le profil candidat est une donnee personnelle rattachee au compte
  // (droit a l'effacement RGPD, voir CLAUDE.md section 10).
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  experiences  Experience[]
  educations   Education[]
  skills       CandidateSkill[]
  generatedCVs GeneratedCV[]
  applications Application[]

  @@map("candidate_profiles")
}

model Experience {
  id                 String    @id @default(cuid())
  candidateProfileId String    @map("candidate_profile_id")
  title              String
  company            String
  location           String?
  startDate          DateTime  @map("start_date")
  endDate            DateTime? @map("end_date")
  description        String?   @db.Text

  // Cascade : supprime avec le profil candidat qui la possede.
  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id                 String    @id @default(cuid())
  candidateProfileId String    @map("candidate_profile_id")
  degree             String
  school             String
  fieldOfStudy       String?   @map("field_of_study")
  startDate          DateTime  @map("start_date")
  endDate            DateTime? @map("end_date")

  // Cascade : supprime avec le profil candidat qui la possede.
  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Skill {
  id   String @id @default(cuid())
  name String @unique

  candidates CandidateSkill[]

  @@map("skills")
}

// Table de jointure explicite (plutot que many-to-many implicite Prisma) pour
// garder un nom de table snake_case conforme a CONVENTIONS.md.
model CandidateSkill {
  candidateProfileId String @map("candidate_profile_id")
  skillId            String @map("skill_id")

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  skill            Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateProfileId, skillId])
  @@map("candidate_skills")
}

model GeneratedCV {
  id                 String   @id @default(cuid())
  candidateProfileId String   @map("candidate_profile_id")
  fileUrl            String   @map("file_url")
  generatedAt        DateTime @default(now()) @map("generated_at")

  // Cascade : supprime avec le profil candidat qui la possede.
  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@map("generated_cvs")
}

// ---------------------------------------------------------------------------
// Entreprises / CFA
// ---------------------------------------------------------------------------

model Company {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  name        String
  siret       String?  @unique
  description String?  @db.Text
  logoUrl     String?  @map("logo_url")
  website     String?
  address     String?
  city        String?
  postalCode  String?  @map("postal_code")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Cascade : le profil entreprise est rattache au compte qui le gere.
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobOffers JobOffer[]

  @@map("companies")
}

model CfaOrganization {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  name        String
  description String?  @db.Text
  logoUrl     String?  @map("logo_url")
  website     String?
  address     String?
  city        String?
  postalCode  String?  @map("postal_code")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Cascade : le profil CFA est rattache au compte qui le gere.
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobOffers JobOffer[]

  @@map("cfa_organizations")
}

// ---------------------------------------------------------------------------
// Offres / candidatures
// ---------------------------------------------------------------------------

model JobOffer {
  id                String         @id @default(cuid())
  // Publiee par une Company OU un CfaOrganization (jamais les deux, jamais
  // aucun) : invariant valide au niveau applicatif (DTO), pas en base.
  companyId         String?        @map("company_id")
  cfaOrganizationId String?        @map("cfa_organization_id")
  title             String
  description       String         @db.Text
  contractType      ContractType   @map("contract_type")
  status            JobOfferStatus @default(DRAFT)
  paymentStatus     PaymentStatus  @default(PENDING) @map("payment_status")
  location          String?
  city              String?
  publishedAt       DateTime?      @map("published_at")
  expiresAt         DateTime?      @map("expires_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Cascade : les offres d'une entreprise/CFA supprime n'ont plus de sens.
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cfaOrganization CfaOrganization? @relation(fields: [cfaOrganizationId], references: [id], onDelete: Cascade)
  applications    Application[]
  payments        Payment[]

  @@map("job_offers")
}

model Application {
  id                 String            @id @default(cuid())
  candidateProfileId String            @map("candidate_profile_id")
  jobOfferId         String            @map("job_offer_id")
  status             ApplicationStatus @default(SENT)
  coverLetter        String?           @map("cover_letter") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  // Cascade : une candidature n'a pas de sens sans le profil ou l'offre associes
  // (droit a l'effacement RGPD cote candidat, nettoyage cote offre supprimee).
  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  jobOffer         JobOffer         @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, jobOfferId])
  @@map("applications")
}

// ---------------------------------------------------------------------------
// Paiement
// ---------------------------------------------------------------------------

model Payment {
  id                    String        @id @default(cuid())
  userId                String        @map("user_id")
  jobOfferId            String?       @map("job_offer_id")
  amountCents           Int           @map("amount_cents")
  currency              String        @default("EUR")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  stripeSessionId       String?       @unique @map("stripe_session_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Pas de cascade : les paiements sont des pieces comptables a conserver
  // (obligation legale de conservation, prioritaire sur l'effacement RGPD).
  user     User      @relation(fields: [userId], references: [id])
  // SetNull : si l'offre est supprimee, la trace de paiement est conservee.
  jobOffer JobOffer? @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)

  @@map("payments")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  // Cascade : les notifications n'ont pas de valeur une fois le compte supprime.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Visioconference
// ---------------------------------------------------------------------------

model VideoRoom {
  id            String          @id @default(cuid())
  hostId        String          @map("host_id")
  participantId String?         @map("participant_id")
  // Genere cote API (UUID non devinable) a la creation, voir CLAUDE.md section 7.
  jitsiRoomName String          @unique @map("jitsi_room_name")
  status        VideoRoomStatus @default(SCHEDULED)
  scheduledAt   DateTime?       @map("scheduled_at")
  startedAt     DateTime?       @map("started_at")
  endedAt       DateTime?       @map("ended_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  // Cascade : une salle n'a pas de sens sans son hote.
  host        User  @relation("VideoRoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  // SetNull : la salle (et son historique) est conservee si le participant est supprime.
  participant User? @relation("VideoRoomParticipant", fields: [participantId], references: [id], onDelete: SetNull)

  @@map("video_rooms")
}
